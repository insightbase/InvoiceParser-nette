{
    "name": "insightbase/invoice-parser-nette",
    "description": "Nette package for parsing invoice/accounting documents from PDF (including scanned PDFs) using Azure Document Intelligence, LLM normalization and Czech-specific validation.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "InsightBase\\InvoiceParserNette\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "InsightBase\\InvoiceParserNette\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.9",
        "nette/di": "^3.1",
        "nette/schema": "^1.3",
        "nette/utils": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "contributte/rabbitmq": "For asynchronous invoice processing workers."
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
